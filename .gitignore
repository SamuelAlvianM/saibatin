# =============================================================================
# Root .gitignore — saibatin monorepo
# Tujuan: keluarkan dependency berat & file rahasia dari Git
# =============================================================================

# --- Rahasia / Environment (JANGAN PERNAH di-commit) -------------------------
.env
.env.*
!.env.example
*.env

# --- Dependency PHP / Laravel ------------------------------------------------
vendor/
composer.phar

# --- Dependency Node / Next.js -----------------------------------------------
node_modules/
.pnp
.pnp.*

# --- Build output ------------------------------------------------------------
.next/
out/
/build
dist/
public/hot
public/storage
bootstrap/cache/*.php

# --- Laravel storage (runtime, log, cache) -----------------------------------
storage/*.key
**/storage/framework/cache/data/*
**/storage/framework/sessions/*
**/storage/framework/views/*
**/storage/logs/*
!**/storage/**/.gitignore

# --- Log & cache umum --------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo
next-env.d.ts

# --- Skrip bantu lokal (berisi kredensial dev, jangan commit) ----------------
mysql-reset.*

# --- Editor / OS -------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.pem
saibatinpesibar_db_pesbar_002.sql

# Berkas lampiran permohonan warga (dokumen pribadi — jangan pernah di-commit;
# transfer ke server via scp/tar, lihat scripts/migrasi-berkas-db-lama.sql)
saibatin-platform/public/uploads/kedatangan/
saibatin-platform/public/uploads/kelahiran_1/
saibatin-platform/public/uploads/kelahiran_2/
saibatin-platform/public/uploads/kematian/
saibatin-platform/public/uploads/kia/
saibatin-platform/public/uploads/kkcetakulang/
saibatin-platform/public/uploads/kknumpang/
saibatin-platform/public/uploads/kkperubahanbiodata/
saibatin-platform/public/uploads/kkpisahkk/
saibatin-platform/public/uploads/kktambahanak/
saibatin-platform/public/uploads/konsolidasiupdatedata/
