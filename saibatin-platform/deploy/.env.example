# Salin ke deploy/.env (gitignored) dan isi nilai ASLI. Ini ENV RUNTIME server
# (di-source oleh deploy.sh → PM2 env_production).
#
# NEXT_PUBLIC_APP_URL WAJIB diisi di sini: deploy.sh me-load berkas ini SEBELUM
# `next build`, sehingga nilainya ikut di-bake ke bundle (metadataBase/Open
# Graph). Bila dikosongkan, Next akan memungut nilai dev dari .env.local dan
# tautan gambar Open Graph di produksi akan menunjuk domain yang salah.
# Generate secret kuat: openssl rand -hex 32

# --- Database MySQL di server (localhost) ------------------------------------
# App (PM2 di server) konek ke MySQL lokal server. User dibuat oleh server-db-setup.sh.
DB_NAME=saibatin
DB_USER=saibatin
DB_PASSWORD=__ISI_PASSWORD_DB_KUAT__
DATABASE_URL="mysql://saibatin:__ISI_PASSWORD_DB_KUAT__@127.0.0.1:3306/saibatin"

# --- Sesi / login (WAJIB, >= 32 char acak) -----------------------------------
AUTH_SECRET=__ISI_STRING_ACAK_MINIMAL_32_KARAKTER__

# --- URL publik app (untuk metadata / email) ---------------------------------
# Pakai IP, atau nip.io: http://saibatin.76.13.19.247.nip.io
APP_URL=http://76.13.19.247
NEXT_PUBLIC_APP_URL=http://76.13.19.247

# --- reCAPTCHA v3 (secret; site key sudah di-bake saat build) ----------------
RECAPTCHA_V3_SECRET_KEY=__ISI_SECRET_KEY__

# --- Email SMTP (OTP pendaftaran, reset password, notifikasi) ----------------
# Brevo (gratis 300/hari, tanpa verifikasi domain — cukup verifikasi sender):
#   MAIL_HOST=smtp-relay.brevo.com  MAIL_PORT=587
#   MAIL_USER=<login SMTP Brevo>    MAIL_PASS=<SMTP key Brevo>
#   MAIL_FROM="Nama Dinas <alamat-sender-terverifikasi@gmail.com>"
# Alternatif Gmail: MAIL_HOST=smtp.gmail.com MAIL_PORT=465 + App Password.
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USER=__LOGIN_SMTP_BREVO__
MAIL_PASS=__SMTP_KEY_BREVO__
MAIL_FROM="Disdukcapil Pesisir Barat <alamat-terverifikasi@gmail.com>"

# --- Kanal OTP pendaftaran (opsional) ----------------------------------------
# Kosong = otomatis: email bila MAIL_* terisi, WhatsApp bila FONNTE_TOKEN ada.
# Paksa salah satu dengan: OTP_CHANNEL=email | OTP_CHANNEL=wa
#OTP_CHANNEL=email

# --- OTP WhatsApp via Fonnte -------------------------------------------------
# Token DEVICE dari dashboard Fonnte (Device → Token), bukan token akun.
# Kosong di production = OTP DILEWATI (register tanpa verifikasi WA).
FONNTE_TOKEN=__ISI_TOKEN_DEVICE_FONNTE__

# --- Halaman Master (buka kunci permohonan final) ----------------------------
# Kosong = /dashboard/master dinonaktifkan (503).
MASTER_PASSWORD=__ISI_PASSWORD_MASTER__

# --- Port app (di belakang Nginx) --------------------------------------------
PORT=3000
